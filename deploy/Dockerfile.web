# ---- React Frontend (build) ----
FROM node:22-slim AS build

WORKDIR /app/apps/web

# Bağımlılıklar
COPY apps/web/package.json ./package.json
RUN npm install

# Kaynak kod
COPY apps/web/ ./

ENV NODE_ENV=production
# Vite üretim derlemesi (çıktı: /app/dist/apps/web)
RUN npm run build

# ---- Nginx ile statik dosyaları servis et + API'ye proxy ----
FROM nginx:1.27-alpine

# Derlenmiş statik dosyalar
COPY --from=build /app/dist/apps/web /usr/share/nginx/html

# SPA + /hcgi/api proxy yapılandırması
COPY deploy/nginx/web.conf /etc/nginx/conf.d/default.conf

EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]
