# =============================================================
# TK AI FİNANCE — Ortam Değişkenleri (Environment Variables)
# Bu dosyayı ".env" olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env
# =============================================================

# ---- Portlar ----
WEB_PORT=3000
API_PORT=5000
POCKETBASE_PORT=8090

# ---- Express API ----
# API sunucusunun dinleyeceği port (container içi). API_PORT ile aynı olmalı.
PORT=5000
# CORS izin verilen origin (domain'iniz). Boş bırakılırsa tüm origin'lere izin verilir.
# Örn: https://alanadiniz.com
CORS_ORIGIN=

# ---- Güvenlik: Binance API anahtarı şifreleme anahtarı ----
# API anahtarları AES-256-GCM ile bu anahtar kullanılarak şifrelenir.
# MUTLAKA güçlü ve rastgele bir değer üretin:
#   openssl rand -hex 32
TRADING_ENC_KEY=

# ---- PocketBase şifreleme anahtarı ----
# PocketBase veri şifrelemesi için (32 karakter önerilir):
#   openssl rand -hex 16
PB_ENCRYPTION_KEY=

# =============================================================
# NOT: Binance API Key / Secret Key kod içinde TUTULMAZ.
# Kullanıcılar bunları arayüzdeki "Binance Bağlantı" panelinden girer;
# değerler TRADING_ENC_KEY ile şifrelenerek sunucuda saklanır.
# =============================================================
