# =============================================================
# Frontend (apps/web) — Ortam Değişkenleri
# Kopyalayın:  cp apps/web/.env.example apps/web/.env
# =============================================================

# Google Analytics 4 measurement id (opsiyonel). Boşsa analytics devre dışıdır.
VITE_GA4_ID=

# --- Sentry Error Tracking & Performance Monitoring ---
# DSN'i https://sentry.io projenizden alın. Boşsa Sentry tamamen devre dışıdır
# (no-op) — geliştirme/preview ortamında güvenli varsayılan budur.
VITE_SENTRY_DSN=

# development | staging | production — boşsa build modundan (dev/prod) türetilir.
VITE_SENTRY_ENVIRONMENT=

# Release/versiyon etiketi, örn. tk-ai-finance@1.4.0
VITE_SENTRY_RELEASE=

# Performans izleme örnekleme oranı (0.0 - 1.0). Varsayılan: 0.2
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2

# Session Replay örnekleme oranı (0.0 - 1.0). Varsayılan: 0 (kapalı).
VITE_SENTRY_REPLAYS_SAMPLE_RATE=0
