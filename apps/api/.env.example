# =============================================================
# Express API — Ortam Değişkenleri
# Docker KULLANMADAN çalıştıracaksanız bu dosyayı ".env" olarak
# kopyalayın:  cp apps/api/.env.example apps/api/.env
# =============================================================

# API sunucusunun portu
PORT=5000

# CORS izin verilen origin (domain'iniz). Boş = tüm origin'ler.
CORS_ORIGIN=

# Binance API anahtarlarını şifrelemek için AES-256-GCM anahtarı.
# Güçlü rastgele değer üretin:  openssl rand -hex 32
TRADING_ENC_KEY=

# ---- Email (SendGrid) ----
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@tkaifinance.com
