# ================= TK AI FİNANCE — PRODUCTION =================
# Copy to .env.production and fill values before deploying.

# ---- Frontend (Vite, VITE_ prefix is exposed to the browser) ----
VITE_API_URL=https://api.domain.com
VITE_POCKETBASE_URL=https://db.domain.com
VITE_GA4_ID=production-ga4-id
VITE_SENTRY_DSN=production-sentry-dsn
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=1.0.0

# ---- Runtime ----
NODE_ENV=production
LOG_LEVEL=info
PORT=5000

# ---- Security / API ----
API_SECRET=production-secret
JWT_SECRET=production-jwt-secret
CORS_ORIGIN=https://domain.com
TRADING_ENC_KEY=generate-with-openssl-rand-hex-32

# ---- Database ----
DATABASE_URL=production-db-url
PB_ENCRYPTION_KEY=generate-with-openssl-rand-hex-16

# ---- Email (SendGrid) ----
SENDGRID_API_KEY=production-sendgrid-key
SENDGRID_FROM_EMAIL=noreply@domain.com
